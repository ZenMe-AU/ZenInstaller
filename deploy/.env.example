TARGET_ENV=zen-installer
SUBSCRIPTION_ID=your-subscription-id
OAUTH_CLIENT_ID=your-github-oauth-client-id
OAUTH_SECRET=your-github-oauth-client-secret
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173 # optional, can be add after deployment
